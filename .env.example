# ── Приложение ─────────────────────────────────────────────
APP_NAME="Corporate AI Assistant"
LOG_LEVEL=INFO
CORS_ORIGINS=*               # для прода — список через запятую

# ── Frontend (Streamlit) ───────────────────────────────────
BACKEND_URL=http://localhost:8000
CHAT_TIMEOUT=180

# ── LLM (Ollama, OpenAI-совместимый endpoint) ──────────────
# Локальный запуск (без Docker): localhost
# В Docker (этап 6) поменяем на http://host.docker.internal:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama          # Ollama игнорирует ключ, но клиент требует непустую строку
LLM_MODEL=qwen3:14b
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=120

# ── Embeddings (Ollama нативный API, БЕЗ /v1) ──────────────
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# ── База данных (PostgreSQL) ───────────────────────────────
# Локально (Docker-контейнер на хосте): localhost
# В docker-compose (этап 7) host станет именем сервиса: ...@db:5432/corpai
DATABASE_URL=postgresql+psycopg2://corpai:corpai@localhost:5433/corpai

# ── RAG / Chroma ───────────────────────────────────────────
# server — отдельный контейнер chroma (этап 6+); embedded — локальная папка
CHROMA_MODE=server
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION=knowledge_base
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=6

# ── Очередь (RabbitMQ) и фоновая обработка ─────────────────
# В docker-compose (этап 7) host станет именем сервиса: ...@rabbitmq:5672/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_QUEUE=document_processing
UPLOAD_DIR=./uploaded_files

# ── docker-compose (этап 7) ────────────────────────────────
# ВАЖНО: версия = твоя установленная версия python-клиента chromadb.
# Узнать: pip show chromadb  → Version. Тег образа сервера и пин клиента в
# образе backend берутся ИЗ ЭТОЙ переменной — они обязаны совпадать.
CHROMA_VERSION=0.5.23
